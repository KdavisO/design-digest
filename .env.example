# Required
FIGMA_TOKEN=
FIGMA_FILE_KEY=

# Optional: filter to specific pages (comma-separated)
# FIGMA_WATCH_PAGES=Home,Settings

# Optional: watch specific node IDs (comma-separated, reduces API cost)
# FIGMA_WATCH_NODE_IDS=

# Optional: Slack notification
# SLACK_WEBHOOK_URL=

# Optional: AI summary
# ANTHROPIC_API_KEY=
# CLAUDE_SUMMARY_ENABLED=true

# Defaults
# SNAPSHOT_DIR=./snapshots
# DRY_RUN=false
