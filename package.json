{
  "name": "design-digest",
  "version": "0.1.0",
  "description": "Automated Figma design change detection with Slack notifications",
  "type": "module",
  "scripts": {
    "diff": "tsx src/diff.ts",
    "diff:dry-run": "DRY_RUN=true tsx src/diff.ts",
    "design-check": "tsx src/design-check.ts",
    "design-check:dry-run": "DRY_RUN=true tsx src/design-check.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "figma",
    "design",
    "diff",
    "slack",
    "notification",
    "design-ops"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "deep-diff": "^1.0.2",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@types/deep-diff": "^1.0.5",
    "@types/node": "^20.11.0",
    "eslint": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
