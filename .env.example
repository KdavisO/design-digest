# ======================
# Required
# ======================

# Figma Personal Access Token (used by both REST API and MCP)
# Referenced from .mcp.json as ${FIGMA_TOKEN}
FIGMA_TOKEN=
FIGMA_FILE_KEY=
# Multiple files: FIGMA_FILE_KEY=key1,key2,key3

# ======================
# Optional: Figma 取得の詳細設定
# ======================

# フィルタ対象ページ（カンマ区切り）
# FIGMA_WATCH_PAGES=Home,Settings

# 特定ノードIDのみ監視（カンマ区切り、API コスト削減）
# FIGMA_WATCH_NODE_IDS=

# ノードツリーの取得深度
# FIGMA_NODE_DEPTH=

# チャンク分割時のバッチサイズ（デフォルト: 5）
# FIGMA_BATCH_SIZE=5

# ======================
# Optional: Slack 通知
# ======================

# Slack Incoming Webhook URL
# SLACK_WEBHOOK_URL=

# Slack 通知のアイコン画像URL
# SLACK_ICON_URL=

# Slack 通知の絵文字アイコン（例: :art:）
# SLACK_ICON_EMOJI=

# ======================
# Optional: AI サマリー
# ======================

# ANTHROPIC_API_KEY=
# CLAUDE_SUMMARY_ENABLED=true

# ======================
# Optional: GitHub Issue 自動作成
# ======================

# GitHub Issue 自動作成の有効化（true/false）
# GITHUB_ISSUE_ENABLED=false

# GitHub トークン（未設定の場合 GITHUB_TOKEN にフォールバック）
# GITHUB_ISSUE_TOKEN=

# Issue 作成先リポジトリ（owner/repo 形式）
# GITHUB_ISSUE_REPO=

# Issue に付与するラベル（カンマ区切り）
# GITHUB_ISSUE_LABELS=

# Issue のアサイン先（カンマ区切り）
# GITHUB_ISSUE_ASSIGNEES=

# ======================
# Optional: Backlog 連携
# ======================

# Backlog 連携の有効化（true/false）
# BACKLOG_ENABLED=false

# Backlog API キー
# BACKLOG_API_KEY=

# Backlog スペースID
# BACKLOG_SPACE_ID=

# Backlog プロジェクトID
# BACKLOG_PROJECT_ID=

# Backlog 課題種別ID
# BACKLOG_ISSUE_TYPE_ID=

# Backlog 優先度ID
# BACKLOG_PRIORITY_ID=

# Backlog 担当者ID
# BACKLOG_ASSIGNEE_ID=

# ======================
# Defaults
# ======================

# スナップショット保存先ディレクトリ
# SNAPSHOT_DIR=./snapshots

# ドライラン（Slack通知をスキップ）
# DRY_RUN=false
