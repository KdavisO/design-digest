# =============================================================================
# 環境変数サンプル
# =============================================================================
# 使い方:
#   1. このファイルを `.env` にコピーする:  cp .env.sample .env
#   2. `.env` に実際の値を記入する
#   3. `.env` を Git にコミットしないことを確認する（`.gitignore` に追加）
#
# 注意:
#   - `.env` への追記だけでは Claude Code / MCP サーバーに自動では渡りません。
#     通常は Claude Code 起動前に `export KEY=...` で環境変数を設定するか、
#     direnv や独自 hook 経由で `.env` を読み込む構成にしてください。
#     詳細はプロジェクトに恒久的に残るドキュメント（例:
#     `.claude/rules/web-delegation.md`）を参照してください。`SETUP.md` にも
#     詳細な手順がありますが、初期セットアップ後に削除されている場合があります。
#   - このファイルはテンプレートのサンプルです。新規にテンプレートから
#     作成したリポジトリでは、初期状態の `.templatesyncignore` に
#     `.env.sample` が含まれるため、テンプレート同期時に上書きされません。
#     既存の下流リポジトリでは `.templatesyncignore` は自動更新されないため
#     （actions-template-sync v2 の仕様）、必要に応じて下流側の
#     `.templatesyncignore` に `.env.sample` を手動で追加してください。
# =============================================================================

# -----------------------------------------------------------------------------
# Brave Search MCP サーバー（オプション・デフォルト無効）
# -----------------------------------------------------------------------------
# 取得先: https://brave.com/search/api/
# 無料プラン: 月 2,000 クエリ
# 用途: 軽量な Web 検索（エラー解決、API 仕様確認、単発の事実確認）
#
# デフォルトでは .mcp.json で disabled: true に設定されており、
# API キーの有無に関わらず Brave Search MCP サーバーは起動されません。
#
# 有効化手順:
#   1. BRAVE_API_KEY に実際の API キーを設定する
#   2. .mcp.json の brave-search エントリから "disabled": true を削除する
#      （または "disabled": false に変更する）
#
# 注意: .mcp.json では項目によって環境変数展開を使う場合がありますが、この
# テンプレート/Claude Code 設定では brave-search の "disabled" を環境変数
# （例: BRAVE_SEARCH_ENABLED=true/false）で切り替える仕組みは用意されていません。
# 有効/無効を切り替える場合は、.mcp.json の brave-search エントリの
# "disabled": true を手動で削除するか、"disabled": false に変更してください。
BRAVE_API_KEY=your-brave-api-key-here

# -----------------------------------------------------------------------------
# o3-search-mcp サーバー（オプション）
# -----------------------------------------------------------------------------
# 取得先: https://platform.openai.com/
# 必須条件: OpenAI API Tier 4 以上
# 用途: 推論付き Web 検索（技術比較、根本原因分析、設計判断）
# コスト: 約 $0.05〜$0.15/回（REASONING_EFFORT 設定による）
OPENAI_API_KEY=your-openai-api-key-here

# o3-search-mcp の検索コンテキストサイズ（low / medium / high）
# 未設定時は medium がデフォルト。high にすると情報量が増えるがコスト増。
# SEARCH_CONTEXT_SIZE=medium

# o3-search-mcp の推論深度（low / medium / high）
# 未設定時は medium がデフォルト。high にすると分析が深まるがコスト増。
# REASONING_EFFORT=medium
